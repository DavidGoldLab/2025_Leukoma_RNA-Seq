--matrix ../4_Final_Mapping/salmon.gene.counts.matrix \
--method edgeR \
--samples_file ../2_Mapping/samples_file.txt

# Generate samples file

echo -e "C\tC1_B1
C\tC1_B2
C\tC2_B1
C\tC2_B2
C\tC3_B1
C\tC4_B2
OA\tOA2_B1
